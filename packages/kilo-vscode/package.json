{
  "name": "relay",
  "displayName": "Relay: Resilient AI Coding Agent",
  "description": "AI coding agent with spec-driven development and multi-provider resilience. Bring your own API keys (Anthropic, Gemini, Moonshot) and never get blocked by a single provider outage. Features inline chat, automated refactoring, terminal control, and customizable agent modes.",
  "version": "0.2.0",
  "icon": "assets/icons/logo-outline-black.png",
  "galleryBanner": {
    "color": "#FFFFFF",
    "theme": "light"
  },
  "publisher": "star-enterprise-solution",
  "repository": {
    "type": "git",
    "url": "https://github.com/star-enterprise-solution/relay.git",
    "directory": "packages/kilo-vscode"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "license": "MIT",
  "author": {
    "name": "Star Enterprise Solutions LLC"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "relay",
    "ai",
    "agent",
    "agentic",
    "coding",
    "coding agent",
    "coding assistant",
    "spec driven",
    "spec-driven development",
    "multi-provider",
    "byok",
    "bring your own key",
    "pair programming",
    "chat",
    "terminal",
    "claude",
    "anthropic",
    "gemini",
    "kimi"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "taskDefinitions": [
      {
        "type": "kilo-worktree-setup",
        "properties": {
          "script": {
            "type": "string",
            "description": "The setup script command to execute"
          }
        }
      }
    ],
    "icons": {
      "kilo-logo": {
        "description": "Kilo Code logo",
        "default": {
          "fontPath": "assets/icons/kilo-icon-font.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "relay-ActivityBar",
          "title": "Relay",
          "icon": "assets/icons/relay-light.svg",
          "darkIcon": "assets/icons/relay-dark.svg"
        }
      ]
    },
    "views": {
      "relay-ActivityBar": [
        {
          "type": "webview",
          "id": "relay.SidebarProvider",
          "name": "Relay"
        }
      ]
    },
