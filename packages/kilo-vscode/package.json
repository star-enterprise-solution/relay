    "submenus": [
      {
        "id": "relay.new.editorContextMenu",
        "label": "Relay"
      },
      {
        "id": "relay.new.terminalContextMenu",
        "label": "Relay"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "relay.new.sidebarTitle.plusButtonClicked",
          "when": "false"
        },
        {
          "command": "relay.new.sidebarTitle.historyButtonClicked",
          "when": "false"
        },
        {
          "command": "relay.new.sidebarTitle.agentManagerOpen",
          "when": "false"
        },
        {
          "command": "relay.new.sidebarTitle.kiloClawOpen",
          "when": "false"
        },
        {
          "command": "relay.new.sidebarTitle.marketplaceButtonClicked",
          "when": "false"
        },
        {
          "command": "relay.new.sidebarTitle.profileButtonClicked",
          "when": "false"
        },
        {
          "command": "relay.new.sidebarTitle.settingsButtonClicked",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "relay.new.sidebarTitle.plusButtonClicked",
          "group": "navigation@0",
          "when": "view == relay.SidebarProvider"
        },
        {
          "command": "relay.new.sidebarTitle.historyButtonClicked",
          "group": "navigation@1",
          "when": "view == relay.SidebarProvider"
        },
        {
          "command": "relay.new.sidebarTitle.agentManagerOpen",
          "group": "navigation@2",
          "when": "view == relay.SidebarProvider"
        },
        {
          "command": "relay.new.sidebarTitle.kiloClawOpen",
          "group": "navigation@3",
          "when": "view == relay.SidebarProvider"
        },
        {
          "command": "relay.new.sidebarTitle.marketplaceButtonClicked",
          "group": "navigation@4",
          "when": "view == relay.SidebarProvider"
        },
        {
          "command": "relay.new.sidebarTitle.profileButtonClicked",
          "group": "navigation@5",
          "when": "view == relay.SidebarProvider"
        },
        {
          "command": "relay.new.sidebarTitle.settingsButtonClicked",
          "group": "navigation@6",
          "when": "view == relay.SidebarProvider"
        }
      ],
      "scm/title": [
        {
          "command": "relay.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "scm/input": [
        {
          "command": "relay.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/title": [
        {
          "command": "relay.new.openInTab",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "relay.new.plusButtonClicked",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == relay.new.TabPanel"
        },
        {
          "command": "relay.new.historyButtonClicked",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == relay.new.TabPanel"
        },
        {
          "command": "relay.new.profileButtonClicked",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == relay.new.TabPanel"
        },
        {
          "command": "relay.new.settingsButtonClicked",
          "group": "navigation@3",
          "when": "activeWebviewPanelId == relay.new.TabPanel"
        }
      ],
      "editor/context": [
        {
          "submenu": "relay.new.editorContextMenu",
          "group": "1_kilocode"
        }
      ],
      "relay.new.editorContextMenu": [
        {
          "command": "relay.new.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "relay.new.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "relay.new.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "relay.new.addToContext",
          "group": "1_actions@4"
        }
      ],
      "terminal/context": [
        {
          "submenu": "relay.new.terminalContextMenu",
          "group": "2_kilocode"
        }
      ],
      "relay.new.terminalContextMenu": [
        {
          "command": "relay.new.terminalAddToContext",
          "group": "1_actions@1"
        },
        {
          "command": "relay.new.terminalFixCommand",
          "group": "1_actions@2"
        },
        {
          "command": "relay.new.terminalExplainCommand",
          "group": "1_actions@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "relay.new.focusChatInput",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "relay.new.toggleAutoApprove",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "relay.new.generateTerminalCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "relay.new.agentManagerOpen",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "relay.new.addToContext",
        "key": "ctrl+k ctrl+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "relay.new.agentManager.previousSession",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.nextSession",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.search",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel' && !terminalFocus"
      },
      {
        "command": "relay.new.agentManager.showTerminal",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.runScript",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel' && (isMac || !terminalFocus)"
      },
      {
        "command": "relay.new.agentManager.toggleDiff",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.showShortcuts",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.newTab",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.newTerminal",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.closeTab",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.newWorktree",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.openWorktree",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.openPR",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.closeWorktree",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.advancedWorktree",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.agentManager.jumpTo9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "activeWebviewPanelId == 'relay.new.AgentManagerPanel'"
      },
      {
        "command": "relay.new.cycleAgentMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "sideBarFocus && relay.new.sidebarVisible || activeWebviewPanelId == 'relay.new.AgentManagerPanel' || activeWebviewPanelId == 'relay.new.TabPanel'"
      },
      {
        "command": "relay.new.cyclePreviousAgentMode",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "sideBarFocus && relay.new.sidebarVisible || activeWebviewPanelId == 'relay.new.AgentManagerPanel' || activeWebviewPanelId == 'relay.new.TabPanel'"
      },
      {
        "command": "relay.new.autocomplete.cancelSuggestions",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && relay.new.autocomplete.hasSuggestions"
      },
      {
        "command": "relay.new.autocomplete.generateSuggestions",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode.autocomplete.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
      },
      {
        "command": "relay.new.autocomplete.showIncompatibilityExtensionPopup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode.autocomplete.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
      },
      {
        "command": "relay.new.autocomplete.nextEdit.acceptOrJump",
        "key": "tab",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && !suggestWidgetVisible && relay.nextEdit.hasPendingSuggestion"
      },
      {
        "command": "relay.new.autocomplete.nextEdit.dismiss",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && relay.nextEdit.hasPendingSuggestion"
      }
    ],
