{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@relay/llm-provider",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "OpenAI-compatible AI SDK provider that points at the Relay LiteLLM gateway. The client half of Relay's multi-provider routing — the gateway itself runs as a separate container (Helm chart or Railway). Used by the VS Code extension and the OpenCode CLI.",
  "keywords": [
    "relay",
    "ai",
    "llm",
    "openai-compatible",
    "litellm",
    "ai-sdk",
    "provider"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./autocomplete": "./src/autocomplete.ts",
    "./fim": "./src/fim.ts",
    "./edit": "./src/edit.ts",
    "./edit-prompt": "./src/edit-prompt.ts",
    "./tui": "./src/tui.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsc",
    "test:ci": "mkdir -p .artifacts/unit && bun test test --reporter=junit --reporter-outfile=.artifacts/unit/junit.xml"
  },
  "dependencies": {
    "@kilocode/plugin": "workspace:*",
    "@ai-sdk/alibaba": "1.0.17",
    "@ai-sdk/anthropic": "3.0.71",
    "@ai-sdk/openai": "3.0.53",
    "@ai-sdk/openai-compatible": "2.0.48",
    "@ai-sdk/mistral": "3.0.27",
    "@openrouter/ai-sdk-provider": "2.9.0",
    "@clack/prompts": "1.0.0-alpha.1",
    "ai": "catalog:",
    "open": "10.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:",
    "solid-js": "catalog:",
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:"
  },
  "peerDependencies": {
    "solid-js": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    },
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  }
}
